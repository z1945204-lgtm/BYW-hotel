{
  "buildCommand": "",
  "outputDirectory": ".",
  "public": true,
  "functions": {},
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/byw-hotel-v3.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
